# 1) CZĄSTKA
/gps/particle gamma

# 2) POZYCJA ŹRÓDŁA:    płaska        powierzchnia (x-y), promień 5 mm, 90 mm przed targetem
/gps/pos/type Plane
/gps/pos/shape Circle
/gps/pos/radius 0.5 mm
/gps/pos/centre  0 0 0 mm # Dokładna pozycja ustawiona na poziomie konfiguracji zadania.

# 3) KIERUNEK: emisja izotropowa, ograniczona do półkuli +Z - stożkowa
/gps/ang/type iso
/gps/ang/mintheta 0 deg
/gps/ang/maxtheta 5 deg
/gps/ang/minphi 0 deg
/gps/ang/maxphi 360 deg


